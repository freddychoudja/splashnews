# Copiez ce fichier vers .env.kamerjob puis renseignez vos identifiants.
# .env.kamerjob est ignoré par Git et ne doit jamais être commité.
KAMERJOB_EMAIL=
KAMERJOB_PASSWORD=

# Rapport de synchronisation par email. REPORT_EMAIL_TO utilise
# KAMERJOB_EMAIL lorsqu'il est laissé vide.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
REPORT_EMAIL_TO=
